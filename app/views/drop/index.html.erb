<div class="app">
  <main class="main">
    <%= render "/drop/drop" %>
  </main>

  <% if(@uploads.present?) %>
    <aside class="sidebar">
      <%= render "/drop/share" %>
    </aside>
  <% else %>
    <%= render "/components/stats" %>
  <% end %>


  <!-- GLOBAL DROP OVERLAY -->
  <div id="globalDrop" class="global-drop">
    <div class="global-drop-inner">
      <p>Drop files to upload</p>
    </div>
  </div>
</div>
